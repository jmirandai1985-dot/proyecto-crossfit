# ============================================
# CONFIGURACIÓN DE ENTORNO - BOX CROSSFIT
# ============================================
# IMPORTANTE: Copia este archivo como .env y completa los valores reales
# NO subas el archivo .env a GitHub (ya está en .gitignore)

# Base de datos PostgreSQL en Neon
# Formato: postgresql://usuario:password@host/database?sslmode=require
DATABASE_URL=postgresql://usuario:password@ep-xxxxx.region.aws.neon.tech/nombredb?sslmode=require

# Seguridad JWT
# Genera una clave secreta segura con: openssl rand -hex 32
JWT_SECRET_KEY=tu_clave_secreta_super_segura_aqui_cambiar_en_produccion
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 horas

# SECRET_KEY para JWT (alternativa simplificada)
SECRET_KEY=urban_training_box_secret_key_2026_jwt

# Configuración de la aplicación
APP_NAME=Box CrossFit Platform
APP_VERSION=1.0.0
DEBUG=True  # Cambiar a False en producción

# CORS (dominios permitidos para el frontend)
# En desarrollo local: http://localhost:5173
# En producción: https://tudominio.com, https://*.tudominio.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Configuración de archivos (futuro: S3 o almacenamiento local)
UPLOAD_DIR=./uploads/vouchers
MAX_UPLOAD_SIZE_MB=5
